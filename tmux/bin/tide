#!/bin/bash

PROGRAM=$(basename $0)
CMD=$1; shift
ROOTDIR=$HOME/code
CACHEDIR=$HOME/.cache/tide
WORKTREE_FILE=$HOME/.cache/tide/worktrees
COLOR_DIM='#928374'
COLOR_ADD='#b8bb26'
REFS=$(awk -F "=" '/refs/ {print $2}' $HOME/.config/tide/config.ini)

cmd_usage() {
    echo "\
Usage: $PROGRAM COMMAND [ARGS]

A simple tmux(1)-based "IDE" with git-worktree(1) and toolbox(1) integration.

Commands:
    open                select worktree from menu
    status [icon|line]  generate status bar (to use from ~/.tmux.conf)
"
    exit 1
}

worktree_list() {
    local repo
    local tree
    local format
    local dim=$(set_color "$COLOR_DIM")
    local add=$(set_color "$COLOR_ADD")
    local reset=$(reset_color)

    find "$ROOTDIR" -maxdepth 3 -name ".git" -type d -printf '%P\n' | \
    sed -e 's|/\.git$||' -e 's|/| |' | sort | \
    while read repo tree; do
        # TODO
        # - adjust parser to this updated format
        format=(
            "%(if)%(worktreepath)%(then)’äĢ%(else)${add}’æŹ%(end)"
            "${repo}/%(refname:lstrip=-1)"
            "${dim}%(if:equals=tag)%(objecttype)%(then)’ÉÆ%(else)¾░ś¼%(end)"
            "%(refname:lstrip=-1) ’ÉŚ %(objectname:short=10) ’æ▓ ${tree}${reset}"
        )

        git -C "$ROOTDIR/$repo/$tree" for-each-ref \
            --format="${format[*]}" ${REFS[*]} | sort -u -k2

        echo "${add}’æŹ $repo/<name> ${dim}’æ▓ ${tree}${reset}"
    done
}

set_color() {
    [ $# == 0 ] && return
    local hex=${1:1}
    local rgb=$(printf "%d;%d;%d\n" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2})
    printf "\x1b[38;2;${rgb}m"
}

reset_color() {
    printf "\x1b[0m"
}

load_worktrees() {
    local repo
    if [ ! -f $WORKTREE_FILE ]; then
        mkdir -p $CACHEDIR
        worktree_list > ${WORKTREE_FILE}.part
        mv ${WORKTREE_FILE}{.part,}
    fi
    if [ "${FZF_PROMPT: -1}" == "/" ]; then
        repo=$(echo "$FZF_PROMPT" | cut -d' ' -f3)
        cat $WORKTREE_FILE | sed -n "s|\(^.\+ \)$repo|\1|p"
    else
        cat $WORKTREE_FILE
    fi
}

cmd_expire() {
    rm -f $WORKTREE_FILE
}

cmd_reload() {
    [ $1 == -r ] && cmd_expire
    load_worktrees
}

cmd_kill() {
    local repo
    local tree
    local session

    read repo tree < <(parse_name "$1")
    name="$repo/$tree"
    session=$(echo "$name" | sed 's/\./-/g')

    if tmux has-session -t="$session" 2>/dev/null; then
        echo "Worktree $session is open, aborting."
        press_key
    fi

    [ -d "$ROOTDIR/$name" ] || return
    confirm "Remove worktree $name" \
    git -C $ROOTDIR/$name worktree remove . || press_key
}

press_key() {
    echo
    echo -n "Press ENTER to continue"
    read
    clear
    exit 1
}

confirm() {
    local prompt=$1; shift
    clear; echo
    read -p "  ${prompt} [y/N]? " -n1 -r
    clear
    if [ "$REPLY" = "y" ]; then
        "$@"
        return $?
    fi
}

parse_name() {
    local name=$(echo "${1:2}" | cut -d' ' -f1)
    local repo=$(echo "$FZF_PROMPT" | cut -d' ' -f3 | head -c-2)
    if [[ $name == */* ]]; then
        echo $name | sed 's|/| |'
    else
        echo $repo $name
    fi
}

header() {
    echo -e "ENTER: open/create, ALT-D: close/remove, ALT-A: toggle all, CTRL-R: reload"
}

cmd_open() {
    local line
    local repo
    local tree
    local root
    local fork

    if [ -n "$TMUX" ]; then
        repo=$(tmux display -p '#S' | xargs dirname)
        if [ "$repo" != "." ]; then
            repo="$repo/"
        else
            repo=
        fi
    else
        repo=
    fi

    local prompt_pre="’Éó Worktree"
    local prompt_all="$prompt_pre "
    local prompt_loc="$prompt_pre $repo"

    export FZF_PROMPT=$prompt_loc
    line=$(load_worktrees | fzf \
         --bind 'ctrl-r:reload(tide reload -r)' \
         --bind 'alt-d:execute(tide kill {})+reload(tide reload -r)' \
         --bind 'alt-w:close' \
         --bind "alt-a:transform([ \${FZF_PROMPT: -1} == '/' ] &&
                 echo 'change-prompt($prompt_all)' ||
                 echo 'change-prompt($prompt_loc)')+reload(tide reload)" \
         --header "$(header)"$'\n\n' \
         +s -n2,4 --ansi --prompt "$prompt_loc")

    [ -z "$line" ] && return
    read repo tree < <(parse_name "$line")
    cd $ROOTDIR/$repo

    if [ "$tree" == "<name>" ]; then
        clear; echo
        read -p "  Enter worktree name: $repo/"
        [ -n "$REPLY" ] || return
        tree=$REPLY
    fi
    if [ ! -d "$tree" ]; then
        root=${line##* }
        git -C "$ROOTDIR/$repo/$root" worktree add ../$tree $tree || press_key
    fi
    cd $tree

    local name=$(echo "$repo/$tree" | sed 's/\./-/g')

    if ! tmux has-session -t="$name" 2>/dev/null; then
        tmux new-session -ds "$name" -n "Code" \
                         -x "$(tput cols)" -y "$(tput lines)" \
                         "sleep 0.1; vim -c GFiles"
        tmux new-window -t "$name" -n "Git" "tig"
        tmux split-window -t "$name" -h -l50 -d
        tmux new-window -t "$name" -n "Build"
        tmux split-window -t "$name" -h -d
        tmux new-window -t "$name" -n "Debug"
        tmux new-window -t "$name" -n "Manual"
        tmux split-window -t "$name" -h
        tmux select-window -t ${name}:+1
        cmd_expire
    fi

    if [ -z "$TMUX" ]; then
        tmux attach -t "$name"
    else
        tmux switch-client -t "$name"
    fi
}

cmd_status() {
    local cmd="$1"
    local session_name="$2"
    local session_path="$3"
    local pane_command="$4"

    print_branch() {
        cd "$session_path"
        git rev-parse --is-inside-work-tree >/dev/null || return 0
        source /usr/share/git-core/contrib/completion/git-prompt.sh
        GIT_PS1_SHOWDIRTYSTATE=1
        GIT_PS1_SHOWSTASHSTATE=1
        GIT_PS1_SHOWUPSTREAM="auto"
        GIT_PS1_STATESEPARATOR=""
        printf "¾░ś¼ $(__git_ps1 '%s')  "
    }

    print_repo() {
        cd "$session_path"
        git rev-parse --is-inside-work-tree >/dev/null || return 0
        printf "’æ▓ $(git rev-parse --path-format=absolute --git-common-dir | \
                    xargs dirname | xargs basename)"
    }

    print_toolbox() {
        local name=$(echo "$session_name" | sed 's/\//-/')
        podman container exists "$name" || return 0
        local pfx=".Config.Labels"
        local key="{{${pfx}.name}}:{{${pfx}.version}}"
        printf "¾░å¦ $(podman inspect --format "$key" "$name")  "
    }

    case $cmd in
        icon)
            shift
            case "$1" in
                Code)   echo "’æÅ " ;;
                Git)    echo "¾░ś¼ " ;;
                Build)  echo "’ÉŻ " ;;
                Debug)  echo "’æ» " ;;
                Manual) echo "’Éģ " ;;
                Blame)  echo "’ō┐ " ;;
                Slack)  echo "¾░Æ▒ " ;;
                Mutt)   echo "¾░ć░ " ;;
                Plan)   echo "’Éģ " ;;
                Dashboard)
                        echo "¾░Ģ« " ;;
                bash)   echo "’Æē " ;;
                *)      echo "’Æē " ;;
            esac
        ;;
        line)
            print_toolbox
            print_branch
            print_repo
        ;;
    esac
}

cmd_refresh() {
    for var in ACCENT_COLOR_BG ACCENT_COLOR_FG FZF_DEFAULT_OPTS; do
        tmux set-environment -g $var "${!var}"
    done
    tmux source-file ~/.tmux.conf
    cmd_expire
}

case $CMD in
    open)               cmd_open "$@" ;;
    reload)             cmd_reload "$@" ;;
    expire)             cmd_expire "$@" ;;
    kill)               cmd_kill "$@" ;;
    status)             cmd_status "$@" ;;
    refresh)            cmd_refresh "$@" ;;
    *)                  cmd_usage ;;
esac
