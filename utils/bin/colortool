#!/usr/bin/python3

import sys
import colorsys

hex, val = sys.argv[1:3]

hex = hex[1:]
rgb = (int(hex[i:i+2], 16) / 255 for i in (0, 2, 4))
hsv = list(colorsys.rgb_to_hsv(*rgb))

hsv[2] *= float(val)

rgb = [round(i * 255) for i in colorsys.hsv_to_rgb(*hsv)]
hex = '#{:02x}{:02x}{:02x}'.format(*rgb)

print(hex)
