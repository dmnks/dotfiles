#!/usr/bin/python3

import sys
import colorsys

hex = sys.argv[1]
if hex[0] == '#':
    hex = hex[1:]
vals = [val for val in sys.argv[2:]]

for val in vals:
    rgb = (int(hex[i:(i + 2)], 16) / 255 for i in (0, 2, 4))
    hsv = list(colorsys.rgb_to_hsv(*rgb))
    hsv[2] *= float(val)
    rgb = [round(i * 255) for i in colorsys.hsv_to_rgb(*hsv)]
    print('#{:02x}{:02x}{:02x}'.format(*rgb))
